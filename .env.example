# MomShell 环境变量配置
# 复制为 .env 后填入实际值

# ==================== 数据库 ====================
DATABASE_URL=postgres://user:password@localhost:5432/momshell?sslmode=disable

# ==================== JWT ====================
# 生产环境务必修改
JWT_SECRET_KEY=change-me-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ==================== OpenAI 兼容 API ====================
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api-inference.modelscope.cn/v1
OPENAI_MODEL=Qwen/Qwen2.5-72B-Instruct

# ==================== 服务端口 ====================
PORT=8000

# ==================== 初始管理员（可选，首次启动自动创建）====================
ADMIN_USERNAME=
ADMIN_EMAIL=
ADMIN_PASSWORD=
